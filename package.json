    "menus": {
      "view/title": [
        {
          "command": "appLab.app.addBrick",
          "when": "view == appLab.appBricks",
          "group": "navigation@0"
        },
        {
          "command": "appLab.app.refreshBricks",
          "when": "view == appLab.appBricks",
          "group": "navigation@1"
        },
        {
          "command": "appLab.app.addSketchLib",
          "when": "view == appLab.appLibs",
          "group": "navigation@0"
        },
        {
          "command": "appLab.app.refreshSketchLibs",
          "when": "view == appLab.appLibs",
          "group": "navigation@1"
        },
        {
          "command": "appLab.newApp",
          "when": "view == appLab.installedApps",
          "group": "navigation@0"
        },
        {
          "command": "appLab.importApp",
          "when": "view == appLab.installedApps",
          "group": "navigation@1"
        },
        {
          "command": "appLab.refreshApps",
          "when": "view == appLab.installedApps",
          "group": "navigation@2"
        },
        {
          "command": "appLab.refreshApps",
          "when": "view == appLab.apps",
          "group": "navigation@0"
        },
        {
          "command": "appLab.refreshBricks",
          "when": "view == appLab.bricks",
          "group": "navigation@0"
        },
        {
          "command": "appLab.model.import",
          "when": "view == appLab.models",
          "group": "navigation@0"
        },
        {
          "command": "appLab.refreshModels",
          "when": "view == appLab.models",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "appLab.app.start",
          "when": "view == appLab.installedApps && viewItem == app:user",
          "group": "inline@0"
        },
        {
          "command": "appLab.app.stop",
          "when": "view == appLab.installedApps && viewItem == app:user:running",
          "group": "inline@0"
        },
        {
          "command": "appLab.app.restart",
          "when": "view == appLab.installedApps && viewItem == app:user:running",
          "group": "inline@1"
        },
        {
          "command": "appLab.app.destroy",
          "when": "view == appLab.installedApps && viewItem == app:user",
          "group": "inline@1"
        },
        {
          "command": "appLab.app.logs",
          "when": "view == appLab.installedApps && viewItem =~ /^app:user/",
          "group": "1_app@0"
        },
        {
          "command": "appLab.setDefaultApp",
          "when": "view == appLab.installedApps && viewItem =~ /^app:user/",
          "group": "2_app@0"
        },
        {
          "command": "appLab.app.destroy",
          "when": "view == appLab.installedApps && viewItem =~ /^app:user/",
          "group": "2_app@1"
        },
        {
          "command": "appLab.app.start",
          "when": "view == appLab.apps && viewItem == app:example",
          "group": "inline@0"
        },
        {
          "command": "appLab.app.stop",
          "when": "view == appLab.apps && viewItem == app:example:running",
          "group": "inline@0"
        },
        {
          "command": "appLab.app.clone",
          "when": "view == appLab.apps && viewItem =~ /^app:example/",
          "group": "inline@1"
        },
        {
          "command": "appLab.app.logs",
          "when": "view == appLab.apps && viewItem =~ /^app:example/",
          "group": "1_app@0"
        },
        {
          "command": "appLab.brick.configure",
          "when": "view == appLab.appBricks && viewItem == appBrick",
          "group": "inline@0"
        },
        {
          "command": "appLab.brick.showDetails",
          "when": "view == appLab.appBricks && viewItem =~ /^appBrick/",
          "group": "1_brick@0"
        },
        {
          "command": "appLab.brick.rename",
          "when": "view == appLab.appBricks && viewItem == appBrick",
          "group": "1_brick@1"
        },
        {
          "command": "appLab.brick.remove",
          "when": "view == appLab.appBricks && viewItem == appBrick",
          "group": "1_brick@2"
        },
        {
          "command": "appLab.sketchLib.remove",
          "when": "view == appLab.appLibs && viewItem == appLib",
          "group": "inline@0"
        },
        {
          "command": "appLab.brick.showDetails",
          "when": "view == appLab.bricks && viewItem == catalogBrick",
          "group": "inline@0"
        },
        {
          "command": "appLab.app.addBrick",
          "when": "view == appLab.bricks && viewItem == catalogBrick",
          "group": "1_brick@0"
        },
        {
          "command": "appLab.model.delete",
          "when": "view == appLab.models && viewItem == model:custom",
          "group": "inline@0"
        },
        {
          "command": "appLab.model.showDetails",
          "when": "view == appLab.models && viewItem =~ /^model:/",
          "group": "1_model@0"
        }
      ],
      "editor/title": [
        {
          "command": "appLab.app.start",
          "when": "appLab.activeAppStatus == stopped",
          "group": "navigation@0"
        },
        {
          "command": "appLab.app.stop",
          "when": "appLab.activeAppStatus == running",
          "group": "navigation@0"
        },
        {
          "command": "appLab.app.restart",
          "when": "appLab.activeAppStatus == running",
          "group": "navigation@1"
        },
        {
          "command": "appLab.app.logs",
          "when": "appLab.activeAppStatus && appLab.activeAppStatus != none",
          "group": "navigation@2"
        },
        {
          "command": "appLab.openMonitor",
          "when": "appLab.activeAppStatus && appLab.activeAppStatus != none",
          "group": "navigation@3"
        },
        {
          "command": "appLab.openPlotter",
          "when": "appLab.activeAppStatus && appLab.activeAppStatus != none",
          "group": "1_io@0"
        },
        {
          "command": "appLab.app.export",
          "when": "appLab.activeAppStatus && appLab.activeAppStatus != none",
          "group": "2_app@1"
        },
        {
          "command": "appLab.app.cleanCache",
          "when": "appLab.activeAppStatus && appLab.activeAppStatus != none",
          "group": "2_app@2"
        },
        {
          "command": "appLab.app.addBrick",
          "when": "appLab.activeAppStatus && appLab.activeAppStatus != none",
          "group": "1_app@0"
        },
        {
          "command": "appLab.app.addSketchLib",
          "when": "appLab.activeAppStatus && appLab.activeAppStatus != none",
          "group": "1_app@1"
        }
      ],
      "commandPalette": [
        {
          "command": "appLab.app.start",
          "when": "false"
        },
        {
          "command": "appLab.app.stop",
          "when": "false"
        },
        {
          "command": "appLab.app.restart",
          "when": "false"
        },
        {
          "command": "appLab.app.destroy",
          "when": "false"
        },
        {
          "command": "appLab.app.logs",
          "when": "false"
        },
        {
          "command": "appLab.app.export",
          "when": "false"
        },
        {
          "command": "appLab.app.clone",
          "when": "false"
        },
        {
          "command": "appLab.app.rename",
          "when": "false"
        },
        {
          "command": "appLab.app.edit",
          "when": "false"
        },
        {
          "command": "appLab.app.openExposedPort",
          "when": "false"
        },
        {
          "command": "appLab.app.revealInExplorer",
          "when": "false"
        },
        {
          "command": "appLab.app.cleanCache",
          "when": "false"
        },
        {
          "command": "appLab.app.addBrick",
          "when": "false"
        },
        {
          "command": "appLab.app.addSketchLib",
          "when": "false"
        },
        {
          "command": "appLab.app.refreshSketchLibs",
          "when": "false"
        },
        {
          "command": "appLab.app.refreshBricks",
          "when": "false"
        },
        {
          "command": "appLab.brick.remove",
          "when": "false"
        },
        {
          "command": "appLab.brick.rename",
          "when": "false"
        },
        {
          "command": "appLab.brick.configure",
          "when": "false"
        },
        {
          "command": "appLab.brick.showDetails",
          "when": "false"
        },
        {
          "command": "appLab.sketchLib.remove",
          "when": "false"
        },
        {
          "command": "appLab.model.delete",
          "when": "false"
        },
        {
          "command": "appLab.model.showDetails",
          "when": "false"
        },
        {
          "command": "appLab.setDefaultApp",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Arduino App Studio",
      "properties": {
        "appLab.daemon.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "%config.daemon.host%"
        },
        "appLab.daemon.port": {
          "type": "number",
          "default": 8800,
          "description": "%config.daemon.port%"
        },
        "appLab.cliPath": {
          "type": "string",
          "default": "arduino-app-cli",
          "description": "%config.cliPath%"
        },
        "appLab.apiKey": {
          "type": "string",
          "default": "",
          "description": "%config.apiKey%"
        },
        "appLab.monitor.lineEnding": {
          "type": "string",
          "enum": [
            "none",
            "lf",
            "cr",
            "crlf"
          ],
          "default": "lf",
          "description": "%config.monitor.lineEnding%"
        },
        "appLab.monitor.autoReconnect": {
          "type": "boolean",
          "default": true,
          "description": "%config.monitor.autoReconnect%"
        },
        "appLab.logs.tail": {
          "type": "number",
          "default": 200,
          "description": "%config.logs.tail%"
        },
        "appLab.updateNotifications": {
          "type": "boolean",
          "default": true,
          "description": "%config.updateNotifications%"
        },
        "appLab.intellisense.autoConfigure": {
          "type": "boolean",
          "default": true,
          "description": "%config.intellisense.autoConfigure%"
        },
        "appLab.arduinoCliPath": {
          "type": "string",
          "default": "",
          "description": "%config.arduinoCliPath%"
        },
        "appLab.python.fastReload": {
          "type": "boolean",
          "default": false,
          "description": "%config.python.fastReload%"
        }
      }
    }
  }
}
