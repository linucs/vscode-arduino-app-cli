{
  "name": "vscode-arduino-app-cli-ide",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.1.1",
  "license": "MIT",
  "publisher": "linucs",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1E1E2E",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/linucs/vscode-arduino-app-cli"
  },
  "bugs": {
    "url": "https://github.com/linucs/vscode-arduino-app-cli/issues"
  },
  "homepage": "https://github.com/linucs/vscode-arduino-app-cli#readme",
  "keywords": [
    "arduino",
    "arduino-app-cli",
    "uno-q",
    "python",
    "machine-learning",
    "ai",
    "computer-vision",
    "edge-impulse",
    "embedded",
    "iot"
  ],
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Education"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "extensionKind": [
    "workspace"
  ],
  "scripts": {
    "vscode:prepublish": "yarn run package",
    "compile": "yarn run check-types && yarn run lint && yarn run check-l10n && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "yarn run check-types && yarn run lint && yarn run check-l10n && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "yarn run compile-tests && yarn run compile && yarn run lint",
    "check-types": "tsc --noEmit",
    "check-l10n": "node scripts/check-l10n.js",
    "lint": "eslint src",
    "test": "vscode-test",
    "deploy:remote": "bash scripts/deploy-remote.sh",
    "gen:stubs": "bash scripts/gen-stubs.sh",
    "check:stubs": "yarn gen:stubs && git diff --exit-code -- stubs && echo 'stubs up to date'",
    "vsix": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@types/ws": "^8.5.13",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "ovsx": "^0.10.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "contributes": {
    "walkthroughs": [
      {
        "id": "appLab.welcome",
        "title": "%walkthrough.title%",
        "description": "%walkthrough.description%",
        "steps": [
          {
            "id": "connect",
            "title": "%walkthrough.connect.title%",
            "description": "%walkthrough.connect.description%",
            "media": { "svg": "images/walkthrough/connect.svg", "altText": "Connecting to the Arduino UNO Q daemon" },
            "completionEvents": ["onCommand:appLab.showVersion"]
          },
          {
            "id": "createApp",
            "title": "%walkthrough.createApp.title%",
            "description": "%walkthrough.createApp.description%",
            "media": { "svg": "images/walkthrough/create-app.svg", "altText": "Creating or importing an app" },
            "completionEvents": ["onCommand:appLab.newApp"]
          },
          {
            "id": "bricksModels",
            "title": "%walkthrough.bricksModels.title%",
            "description": "%walkthrough.bricksModels.description%",
            "media": { "svg": "images/walkthrough/bricks-models.svg", "altText": "Bricks and models catalogs" },
            "completionEvents": ["onCommand:appLab.app.addBrick"]
          },
          {
            "id": "runApp",
            "title": "%walkthrough.runApp.title%",
            "description": "%walkthrough.runApp.description%",
            "media": { "svg": "images/walkthrough/run-app.svg", "altText": "Running an app and watching the console" },
            "completionEvents": ["onCommand:appLab.app.start"]
          },
          {
            "id": "monitor",
            "title": "%walkthrough.monitor.title%",
            "description": "%walkthrough.monitor.description%",
            "media": { "svg": "images/walkthrough/monitor.svg", "altText": "Serial monitor and data plotter" },
            "completionEvents": ["onCommand:appLab.openMonitor"]
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "appLab",
          "title": "%viewContainer.appLab%",
          "icon": "images/activitybar.svg"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "appLab.appBricks",
          "name": "%view.appBricks%"
        },
        {
          "id": "appLab.appLibs",
          "name": "%view.appLibs%"
        }
      ],
      "appLab": [
        {
          "id": "appLab.installedApps",
          "name": "%view.installedApps%"
        },
        {
          "id": "appLab.apps",
          "name": "%view.examples%"
        },
        {
          "id": "appLab.bricks",
          "name": "%view.brickCatalog%"
        },
        {
          "id": "appLab.models",
          "name": "%view.models%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "appLab.installedApps",
        "when": "appLab.daemonState == 'disconnected'",
        "contents": "%welcome.daemonUnreachable%"
      },
      {
        "view": "appLab.apps",
        "when": "appLab.daemonState == 'disconnected'",
        "contents": "%welcome.daemonUnreachable%"
      },
      {
        "view": "appLab.bricks",
        "when": "appLab.daemonState == 'disconnected'",
        "contents": "%welcome.daemonUnreachable%"
      },
      {
        "view": "appLab.models",
        "when": "appLab.daemonState == 'disconnected'",
        "contents": "%welcome.daemonUnreachable%"
      }
    ],
