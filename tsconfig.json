{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"lib": [
			"ES2022"
		],
		"sourceMap": true,
		"rootDir": "src",
		"resolveJsonModule": true,
		"skipLibCheck": true,   /* skip type-checking of dependency .d.ts files */
		"strict": true   /* enable all strict type-checking options */
	},
	"exclude": [
		"node_modules",
		".vscode-test"
	]
}
